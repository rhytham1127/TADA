              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"account_name\": \"John Doe\",\n  \"bank_name\": \"State Bank of India\",\n  \"account_number\": \"1234567890\",\n  \"ifsc_code\": \"SBIN0001234\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/bank",
              "host": ["{{base_url}}"],
              "path": ["bank"]
            }
          },
          "response": []
        },
        {
          "name": "Get Bank Details",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/bank",
              "host": ["{{base_url}}"],
              "path": ["bank"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "File Upload",
      "item": [
        {
          "name": "Upload Files",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "files",
                  "type": "file",
                  "src": []
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/upload/{{form_id}}",
              "host": ["{{base_url}}"],
              "path": ["upload", "{{form_id}}"]
            }
          },
          "response": []
        },
        {
          "name": "Get Files",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/upload/{{form_id}}",
              "host": ["{{base_url}}"],
              "path": ["upload", "{{form_id}}"]
            }
          },
          "response": []
        },
        {
          "name": "Delete File",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/upload/{{file_id}}",
              "host": ["{{base_url}}"],
              "path": ["upload", "{{file_id}}"]
            }
          },
          "response": []
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000/api"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "form_id",
      "value": ""
    },
    {
      "key": "expense_id",
      "value": ""
    },
    {
      "key": "file_id",
      "value": ""
    }
  ]
}
